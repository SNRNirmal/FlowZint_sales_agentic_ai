# --- LLM Provider (gemini | anthropic | qwen) ---
# Switch to LLM_PROVIDER=qwen for local Ollama testing
LLM_PROVIDER=gemini

# Google Gemini (default provider)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic (optional alternative)
ANTHROPIC_API_KEY=your_key_here
LLM_MODEL=claude-sonnet-4-6

# Ollama / Qwen (local testing only — requires ollama serve + ollama pull qwen3:8b)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
# --- Database ---
DATABASE_URL=sqlite:///./threshold.db
# For Postgres: postgresql://user:password@localhost:5432/threshold

# --- Slack (optional for demo; can be mocked) ---
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_DEFAULT_CHANNEL=#deal-approvals

# --- Email (optional for demo; can be mocked) ---
EMAIL_SENDER=threshold@yourcompany.com
EMAIL_API_KEY=your_key_here

# --- App ---
APP_ENV=development
